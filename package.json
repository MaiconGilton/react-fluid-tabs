{
  "name": "react-fluid-tabs-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpx @biomejs/biome lint .",
    "format": "pnpx @biomejs/biome format --write .",
    "check": "pnpx @biomejs/biome check --write .",
    "release:package": "pnpm build && pnpx standard-version && git push --follow-tags",
    "publish:package": "pnpm --filter react-fluid-tabs publish --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "standard-version": "^9.5.0"
  },
  "packageManager": "pnpm@9.0.0"
}